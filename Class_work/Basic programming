
# program to perform numeric calculation

# creating variables to store numbers
num1 = 10
num2 = 5

# performing addition
add = num1 + num2
print("The addition of", num1, "and", num2, "is", add)

# performing subtraction
sub = num1 - num2
print("The subtraction of", num1, "and", num2, "is", sub)

# performing multiplication
mul = num1 * num2
print("The multiplication of", num1, "and", num2, "is", mul)

# performing division
div = num1 / num2
print("The division of", num1, "and", num2, "is", div)

'''
Output:
